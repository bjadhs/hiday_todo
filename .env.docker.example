# Copy this to `.env` on the server (next to docker-compose.yml) and fill in.
# docker compose reads it automatically for ${VAR} substitution.
# This file is the ONLY place credentials live — never commit the real `.env`.

# Postgres (also used to build the app's DATABASE_URL inside the compose network)
POSTGRES_USER=hiday_todo
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hiday_todo

# Shared password that gates the whole app.
APP_PASSWORD=change-me

# Secret used to sign the session cookie.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string

# How many days of pg_dump backups to keep in ./backups (optional, default 7).
BACKUP_RETENTION_DAYS=7
