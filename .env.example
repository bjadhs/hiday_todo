# Postgres connection string (existing Hostinger Postgres; use a dedicated DB+user).
# Local dev example: 
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hiday_todo

# Shared password that gates the whole app.
APP_PASSWORD=change-me

# Secret used to sign the session cookie (use a long random string).
# Generate one with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string
